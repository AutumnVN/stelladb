---
interface Props {
    placeholder?: string;
    noResultsText?: string;
}

import SearchInput from '@/components/SearchInput.astro';

const { placeholder = 'Search...', noResultsText = 'No results found.' } = Astro.props as Props;
---

<div class="searchable-grid">
    <SearchInput placeholder={placeholder} />

    <div class="grid">
        <slot />
    </div>

    <div class="no-results" hidden>{noResultsText}</div>
</div>

<script>
    // @ts-nocheck
    (function () {
        const input = document.querySelector('#search');
        const grid = document.querySelector('.grid');
        const noResults = document.querySelector('.no-results');

        const items = () => Array.from(grid.querySelectorAll('.card-item'));

        function splitOr(s) {
            if (!s) return [];
            const parts = [];
            let buf = '';
            let inQuotes = false;

            for (let i = 0; i < s.length; i++) {
                const ch = s[i];
                if (ch === '"') {
                    inQuotes = !inQuotes;
                    buf += ch;
                    continue;
                }

                if (!inQuotes && ch === '|') {
                    const prev = s[i - 1] || '';
                    const next = s[i + 1] || '';
                    if (/\s/.test(prev) && /\s/.test(next)) {
                        const part = buf.trim();
                        if (part) parts.push(part);
                        buf = '';
                        continue;
                    }
                }

                buf += ch;
            }

            const last = buf.trim();
            if (last) parts.push(last);
            return parts;
        }

        function tokenizeClause(s) {
            if (!s) return [];
            const tokens = [];
            let buf = '';
            let inQuotes = false;

            for (let i = 0; i < s.length; i++) {
                const ch = s[i];
                if (ch === '"') {
                    inQuotes = !inQuotes;
                    buf += ch;
                    continue;
                }

                if (!inQuotes && /\s/.test(ch)) {
                    const tok = buf.trim();
                    if (tok) tokens.push(tok);
                    buf = '';
                    continue;
                }

                buf += ch;
            }

            const last = buf.trim();
            if (last) tokens.push(last);
            return tokens;
        }

        function splitAlternates(s) {
            if (!s) return [];
            const parts = [];
            let buf = '';
            let inQuotes = false;

            for (let i = 0; i < s.length; i++) {
                const ch = s[i];
                if (ch === '"') {
                    inQuotes = !inQuotes;
                    buf += ch;
                    continue;
                }

                if (!inQuotes && ch === '|') {
                    const part = buf.trim();
                    if (part) parts.push(part);
                    buf = '';
                    continue;
                }

                buf += ch;
            }

            const last = buf.trim();
            if (last) parts.push(last);
            return parts;
        }

        function stripQuotes(s) {
            const text = (s || '').trim();
            if (text.length >= 2 && text.startsWith('"') && text.endsWith('"')) {
                return text.slice(1, -1);
            }
            return text;
        }

        function parseToken(tok) {
            const t = tok || '';
            const m = t.match(/^([^<>=!\s]+)\s*(<=|>=|!=|=|<|>)\s*(.*)$/);
            if (m) {
                const val = stripQuotes(m[3] || '');
                return { type: 'key', key: m[1], op: m[2], value: val };
            }
            const text = stripQuotes(t);
            return { type: 'general', text };
        }

        function parseQuery(q) {
            if (!q) return [];
            const orParts = splitOr(q);
            return orParts.map((part) => {
                const rawTokens = tokenizeClause(part);
                const segments = [];
                const keyed = {};

                rawTokens.forEach((tokStr) => {
                    const alts = splitAlternates(tokStr);
                    const parsedAlts = alts.map((alt) => parseToken(alt));

                    if (parsedAlts.length === 1 && parsedAlts[0].type === 'key') {
                        const p = parsedAlts[0];
                        if (!keyed[p.key]) keyed[p.key] = [];
                        keyed[p.key].push({ op: p.op, value: p.value });
                    } else {
                        segments.push(parsedAlts);
                    }
                });

                return { segments, keyed };
            });
        }

        function getAttrValue(item, key) {
            const ds = item.dataset || {};
            if (ds[key] !== undefined) return ds[key];
            const kebab = key.replace(/([A-Z])/g, '-$1').toLowerCase();
            const attr = item.getAttribute && item.getAttribute('data-' + kebab);
            if (attr !== null) return attr;
            return '';
        }

        function compareValues(itemValRaw, op, targetRaw) {
            const itemVal = (itemValRaw || '').toString().trim();
            const target = (targetRaw || '').toString().trim();
            const numItem = parseFloat(itemVal);
            const numTarget = parseFloat(target);
            const bothNumber = !isNaN(numItem) && !isNaN(numTarget);
            if (op === '=') {
                if (bothNumber) return numItem === numTarget;
                return itemVal.toLowerCase().includes(target.toLowerCase());
            }
            if (op === '!=') {
                if (bothNumber) return numItem !== numTarget;
                return !itemVal.toLowerCase().includes(target.toLowerCase());
            }
            if (!bothNumber) return false;
            if (op === '>') return numItem > numTarget;
            if (op === '<') return numItem < numTarget;
            if (op === '>=') return numItem >= numTarget;
            if (op === '<=') return numItem <= numTarget;
            return false;
        }

        function matchClause(item, clause) {
            const ds = item.dataset || {};
            const keyOnly = ds.key === 'true';
            const combinedGeneral = Object.keys(ds)
                .filter((k) => k !== 'key')
                .map((k) => ds[k])
                .join(' ');
            const combinedAll = keyOnly ? '' : (combinedGeneral + ' ' + (item.textContent || '')).trim();

            let segmentsPass = true;
            for (const seg of clause.segments || []) {
                let anyAlt = false;
                for (const alt of seg) {
                    if (alt.type === 'general') {
                        if (combinedAll.toLowerCase().includes(alt.text.toLowerCase())) {
                            anyAlt = true;
                            break;
                        }
                    } else if (alt.type === 'key') {
                        const v = getAttrValue(item, alt.key) || '';
                        if (compareValues(v, alt.op, alt.value)) {
                            anyAlt = true;
                            break;
                        }
                    }
                }
                if (!anyAlt) {
                    segmentsPass = false;
                    break;
                }
            }

            let keyedPass = true;
            for (const key in clause.keyed) {
                const conds = clause.keyed[key];
                const itemVal = getAttrValue(item, key) || '';
                let anyForKey = false;
                for (const c of conds) {
                    if (compareValues(itemVal, c.op, c.value)) {
                        anyForKey = true;
                        break;
                    }
                }
                if (!anyForKey) {
                    keyedPass = false;
                    break;
                }
            }

            return segmentsPass && keyedPass;
        }

        function matches(item, q) {
            if (!q) return true;
            const clauses = parseQuery(q);
            if (!clauses.length) return true;
            for (const clause of clauses) {
                if (matchClause(item, clause)) return true;
            }
            return false;
        }

        let timeout = null;
        function onInput() {
            const q = input?.value?.trim() || '';
            if (timeout) clearTimeout(timeout);
            timeout = setTimeout(() => {
                let anyMatched = false;
                items().forEach((item) => {
                    const matched = matches(item, q);
                    item.style.display = matched ? '' : 'none';
                    if (matched) anyMatched = true;
                });
                if (noResults) noResults.hidden = anyMatched;
            }, 150);
        }

        if (input) input.addEventListener('input', onInput);
    })();
</script>

<style>
    .searchable-grid {
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .no-results {
            margin-top: 2rem;
            color: var(--text);
            font-size: 1.5rem;
            text-align: center;
        }
    }
</style>
