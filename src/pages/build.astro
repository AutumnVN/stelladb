---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Build Preset | stelladb">
    <div class="search-wrap">
        <label for="search" class="visually-hidden">Search</label>
        <input id="search" type="search" placeholder="Build preset id" autofocus />
    </div>
</Layout>

<script>
    // @ts-nocheck
    const input = document.querySelector('#search');
    if (input) {
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                const val = input.value.trim();
                if (val) window.location.href = `/build/${val}`;
            }
        });
    }
</script>

<style>
    .search-wrap {
        display: flex;
        position: sticky;
        top: var(--nav-height);
        z-index: 1;
        background: var(--bg1a);
        padding: 1rem;
    }
    input[type='search'] {
        width: 100%;
        backdrop-filter: blur(5px);
        border: var(--muted) 3px solid;
        border-radius: 6px;
        background: var(--bg1a);
        padding: 0.75rem;
        color: var(--text);
        accent-color: var(--accent);
        font-size: 1.25rem;
    }

    .visually-hidden {
        position: absolute !important;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(1px, 1px, 1px, 1px);
        margin: -1px;
        border: 0;
        padding: 0;
        white-space: nowrap;
    }
</style>
