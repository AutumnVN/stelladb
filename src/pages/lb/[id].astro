---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import Tabs from '@/components/Tabs.astro';
import { packPotentialData } from '@/scripts/potentialPack.js';

export const prerender = false;

const { params, request } = Astro;
const id = params.id;

const DATA_URL = `https://raw.githubusercontent.com/AutumnVN/ssleaderboard/refs/heads/main/${id}.json`;

const data = await fetch(DATA_URL).then((res) => res.json());
if (!data) {
    throw Astro.redirect('/404');
}

const META_URL = 'https://raw.githubusercontent.com/AutumnVN/ssleaderboard/refs/heads/main/meta.json';
const BLITZ_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/blitz.json';
const RAID_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/raid.json';
const CHARACTER_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/character.json';
const DISC_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/disc.json';

const meta = await fetch(META_URL).then((res) => res.json());
const blitzData = await fetch(BLITZ_URL).then((res) => res.json());
const raidData = await fetch(RAID_URL).then((res) => res.json());
const characterData = await fetch(CHARACTER_URL).then((res) => res.json());
const discData = await fetch(DISC_URL).then((res) => res.json());
const POTENTIAL_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/EN/bin/CharPotential.json';
const potentialData = await fetch(POTENTIAL_URL)
    .then((res) => res.json())
    .catch(() => ({}));

function mapTeamPotentials(team) {
    const teamPots = team.Potentials || [];
    const mappedPots = teamPots.map((p) => ({ Id: p.PotentialId, Level: p.Level }));
    const chars = team.Chars;
    const tb = [];
    for (let i = 0; i < 3; i++) {
        const c = chars[i];
        tb.push({ CharId: c.Id, Potentials: mappedPots });
    }
    return tb;
}

if (data.Rank) {
    for (const entry of data.Rank) {
        for (const team of entry.Teams) {
            const tb = mapTeamPotentials(team);
            team.Code = packPotentialData(tb, potentialData);
        }
    }
}

if (data.Self.Teams) {
    for (const team of data.Self.Teams) {
        const tb = mapTeamPotentials(team);
        team.Code = packPotentialData(tb, potentialData);
    }
}

const isBB = id.slice(0, 2) === 'bb';
const name = isBB ? `Boss Blitz S${id.slice(2)}` : `Finale Echoing S${id.slice(2)}`;
const floorData = isBB ? blitzData : raidData;
const floor = meta[id];

const charCounts = {};
const charUsers = {};
for (const entry of data.Rank) {
    const playerChars = new Set();
    for (const team of entry.Teams) {
        for (const c of team.Chars) {
            playerChars.add(+c.Id);
        }
    }
    for (const cid of playerChars) {
        if (!charCounts[cid]) charCounts[cid] = 0;
        charCounts[cid] += 1;
        if (!charUsers[cid]) charUsers[cid] = [];
        charUsers[cid].push({ id: entry.Id, name: entry.NickName, rank: entry.Rank });
    }
}

const usageList = Object.keys(charCounts)
    .map((k) => {
        const idNum = +k;
        const charInfo = characterData[idNum];
        const name = charInfo.name;
        const users = charUsers[k].map((u) => ({ id: u.id, name: u.name, rank: u.rank }));
        return { id: idNum, count: charCounts[k], name, users };
    })
    .sort((a, b) => b.count - a.count);

let prevCount = null;
let currentRank = 0;
for (let i = 0; i < usageList.length; i++) {
    if (usageList[i].count !== prevCount) currentRank = i + 1;
    usageList[i].rank = currentRank;
    prevCount = usageList[i].count;
}
function headIconUrl(icon) {
    const prefix = icon > 100000 || [101, 102].includes(icon) ? 'player' : '';
    const id = icon === 101 ? 10001 : icon === 102 ? 10101 : icon;
    return `https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/${prefix}head/${prefix}head_${id}_XXL.webp`;
}
---

<Layout title={`${name} Leaderboard | stelladb`} description={`${data.Total.toLocaleString('en-US')} players total${data.Rank[0] ? `, #1 ${data.Rank[0].NickName}: ${data.Rank[0].Score.toLocaleString('en-US')}` : ''}`} image={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/${isBB ? 'mapchallenge' : 'monster'}/${floorData[floor[0]]?.icon}.webp`}>
    <div class="leaderboard-page" data-json={JSON.stringify(data)} data-floor={JSON.stringify(floorData)} data-chars={JSON.stringify(characterData)}>
        <div class="header">
            <h1>{name} Leaderboard</h1>
            <p>
                {data.Total.toLocaleString('en-US')} players total<br />
                last updated <span class="update-time" data-time={data.LastRefreshTime * 1000}></span>
            </p>
        </div>

        <div class="content">
            <div class="leaderboard-grid">
                <div class="grid-header">
                    <div class="col rank">Rank</div>
                    <div class="col player">Player</div>
                    <div class="col score">Score</div>
                    <div class="col details">Details</div>
                </div>

                {
                    data.Rank.map((entry) => (
                        <div class="grid-row" data-id={entry.Id}>
                            <div class="col rank">
                                <div class="rank-num">{entry.Rank}</div>
                            </div>

                            <div class="col player">
                                <img class="player-head" src={headIconUrl(entry.HeadIcon)} alt={entry.NickName} title={entry.NickName} width="48" height="48" />
                                <div class="player-name">{entry.NickName}</div>
                            </div>

                            <div class="col score">{entry.Score.toLocaleString('en-US')}</div>

                            <div class="col details">
                                <button class="details-btn" data-id={entry.Id}>
                                    🔍
                                </button>
                            </div>
                        </div>
                    ))
                }

                {
                    data.Self?.Rank && (
                        <div class="grid-row self-row" data-id={data.Self.Id}>
                            <div class="col rank">
                                <div class="rank-num">{data.Self.Rank}</div>
                            </div>

                            <div class="col player">
                                <img class="player-head" src={headIconUrl(data.Self.HeadIcon)} alt={data.Self.NickName} title={data.Self.NickName} width="48" height="48" />
                                <div class="player-name">{data.Self.NickName}</div>
                            </div>

                            <div class="col score">{data.Self.Score.toLocaleString('en-US')}</div>

                            <div class="col details">
                                <button class="details-btn" data-id={data.Self.Id}>
                                    🔍
                                </button>
                            </div>
                        </div>
                    )
                }

                <div id="team-modal" class="team-modal hidden">
                    <div class="modal-backdrop" id="team-modal-backdrop"></div>
                    <div class="modal-panel">
                        <button class="modal-close" id="team-modal-close">×</button>
                        <div class="modal-content" id="team-modal-content"></div>
                    </div>
                </div>
            </div>

            <div class="char-usage">
                <h2>Trekker usage in top 100</h2>
                <div class="usage-grid">
                    <div class="grid-header">
                        <div class="col rank">Rank</div>
                        <div class="col char">Trekker</div>
                        <div class="col uses">Uses</div>
                    </div>

                    {
                        usageList.length ? (
                            usageList.map((item) => (
                                <div class="grid-row" data-id={item.id}>
                                    <div class="col rank">
                                        <div class="rank-num">{item.rank}</div>
                                    </div>

                                    <div class="col char">
                                        <a class="char-link" href={`/trekker/${item.id}`}>
                                            <img class="char-icon" src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/head/head_${item.id}02_XXL.webp`} alt={item.name} title={item.name} width="48" height="48" />
                                            <div class="player-name">{item.name}</div>
                                        </a>
                                    </div>

                                    <div class="col uses">{item.count === 1 && item.users && item.users.length === 1 ? `#${item.users[0].rank} ${item.users[0].name}` : item.count}</div>
                                </div>
                            ))
                        ) : (
                            <div class="grid-row">
                                <div class="col">No usage data</div>
                            </div>
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    // @ts-nocheck
    const updateTimeEl = document.querySelector('.update-time');
    const updateTime = new Date(+updateTimeEl.dataset.time);

    updateTimeEl.textContent = formatRelativeTime(updateTime);
    setInterval(() => {
        updateTimeEl.textContent = formatRelativeTime(updateTime);
    }, 1000);

    function formatRelativeTime(time) {
        const now = new Date();
        const diff = time - now;
        const absDiff = Math.abs(diff);

        let relativeTime;
        if (absDiff < 60 * 1000) {
            relativeTime = `${Math.floor(absDiff / 1000)} second${Math.floor(absDiff / 1000) !== 1 ? 's' : ''}`;
            relativeTime = diff < 0 ? `${relativeTime} ago` : `in ${relativeTime}`;
        } else if (absDiff < 60 * 60 * 1000) {
            relativeTime = `${Math.floor(absDiff / (60 * 1000))} minute${Math.floor(absDiff / (60 * 1000)) !== 1 ? 's' : ''}`;
            relativeTime = diff < 0 ? `${relativeTime} ago` : `in ${relativeTime}`;
        } else if (absDiff < 24 * 60 * 60 * 1000) {
            relativeTime = `${Math.floor(absDiff / (60 * 60 * 1000))} hour${Math.floor(absDiff / (60 * 60 * 1000)) !== 1 ? 's' : ''}`;
            relativeTime = diff < 0 ? `${relativeTime} ago` : `in ${relativeTime}`;
        } else {
            relativeTime = `${Math.floor(absDiff / (24 * 60 * 60 * 1000))} day${Math.floor(absDiff / (24 * 60 * 60 * 1000)) !== 1 ? 's' : ''}`;
            relativeTime = diff < 0 ? `${relativeTime} ago` : `in ${relativeTime}`;
        }
        return relativeTime;
    }

    const pageEl = document.querySelector('.leaderboard-page');

    const pageData = JSON.parse(pageEl.dataset.json);
    const floorMap = JSON.parse(pageEl.dataset.floor);
    const charMap = JSON.parse(pageEl.dataset.chars);

    const modal = document.getElementById('team-modal');
    const modalContent = document.getElementById('team-modal-content');
    const modalClose = document.getElementById('team-modal-close');
    const modalBackdrop = document.getElementById('team-modal-backdrop');

    function headIconUrl(icon) {
        const prefix = icon > 100000 || [101, 102].includes(icon) ? 'player' : '';
        const id = icon === 101 ? 10001 : icon === 102 ? 10101 : icon;
        return `https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/${prefix}head/${prefix}head_${id}_XXL.webp`;
    }

    function openModal(entry) {
        modalContent.innerHTML = '';
        const h = document.createElement('div');
        h.className = 'modal-heading';

        const ph = document.createElement('img');
        ph.className = 'player-head modal-player-head';
        const phUrl = headIconUrl(entry.HeadIcon);
        if (phUrl) ph.src = phUrl;
        ph.alt = entry.NickName;
        ph.width = 48;
        ph.height = 48;
        h.appendChild(ph);

        const titleText = document.createElement('div');
        titleText.textContent = `${entry.NickName} • Rank: ${entry.Rank}`;
        h.appendChild(titleText);

        modalContent.appendChild(h);

        entry.Teams.sort((a, b) => a.LevelId - b.LevelId).forEach((t, i) => {
            const teamEl = document.createElement('div');
            teamEl.className = 'modal-team';
            const title = document.createElement('div');
            title.className = 'modal-team-title';
            const levelName = floorMap[t.LevelId]?.name;
            title.textContent = `Team ${i + 1}: ${levelName} • ${t.LevelScore.toLocaleString('en-US')}`;
            teamEl.appendChild(title);

            const charsWrap = document.createElement('div');
            charsWrap.className = 'modal-chars';
            t.Chars.forEach((c) => {
                const charInfo = charMap[c.Id];
                const charName = charInfo.name;
                const card = document.createElement('a');
                card.className = 'modal-char-card';
                card.href = `/trekker/${c.Id}`;
                card.title = charName;

                const img = document.createElement('div');
                img.className = 'modal-char-image';
                img.style.backgroundImage = `url(https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/head/head_${c.Id}02_XXL.webp)`;
                card.appendChild(img);

                const label = document.createElement('div');
                label.className = 'modal-char-label';
                label.textContent = `${charName} • Lv${c.Level}`;
                card.appendChild(label);

                charsWrap.appendChild(card);
            });

            const teamRow = document.createElement('div');
            teamRow.className = 'modal-team-row';

            const left = document.createElement('div');
            left.className = 'modal-team-left';
            left.appendChild(charsWrap);
            teamRow.appendChild(left);

            const buildWrap = document.createElement('div');
            buildWrap.className = 'modal-build-wrap';
            const buildLink = document.createElement('a');
            buildLink.className = 'modal-build-link';
            buildLink.href = `/build/${t.Code}`;
            buildLink.target = '_blank';
            buildLink.textContent = 'Open build';
            buildWrap.appendChild(buildLink);
            teamRow.appendChild(buildWrap);
            teamEl.appendChild(teamRow);
            modalContent.appendChild(teamEl);
        });
        modal.classList.remove('hidden');
    }

    function closeModal() {
        modal.classList.add('hidden');
    }

    document.querySelectorAll('.details-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
            const id = btn.dataset.id;
            const entry = pageData.Self.Id === id ? pageData.Self : pageData.Rank.find((e) => e.Id === id);
            openModal(entry);
        });
    });

    modalClose.addEventListener('click', closeModal);
    modalBackdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
    });
</script>

<style>
    .header {
        display: flex;
        position: sticky;
        top: var(--nav-height);
        align-items: center;
        backdrop-filter: blur(5px);
        margin: 0 auto;
        background: var(--bg1a);
        padding: 0 1rem;
        max-width: 1000px;
        height: var(--nav-height);
    }

    .header p {
        margin-left: auto;
        color: var(--muted);
        text-align: right;
    }

    h1 {
        margin: 0 1rem 0 0;
        font-weight: 700;
        font-size: 1.5rem;
    }

    h2 {
        margin-left: 1rem;
        font-weight: 700;
        font-size: 1.5rem;
    }

    .leaderboard-grid {
        max-width: 1000px;
        width: 100%;
        margin: 0 auto;
    }

    .grid-header,
    .grid-row {
        display: grid;
        grid-template-columns: 100px 1fr 140px 50px;
        gap: 1rem;
        align-items: center;
        padding: 0.6rem 1rem;
        border-bottom: 1px solid var(--bg2);
    }

    .grid-header {
        font-size: 0.8rem;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 600;
    }

    .grid-row .rank-num {
        font-weight: 700;
        font-size: 1.75rem;
    }

    .player {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .player-head {
        width: 48px;
        height: 48px;
        border-radius: 4px;
        object-fit: cover;
        background: var(--bg2);
    }

    .player-name {
        font-weight: 600;
    }

    .score {
        font-weight: 700;
        text-align: center;
    }

    .self-row {
        border-top: 3px solid var(--accent);
        padding: 0.6rem 1rem;
    }

    @media (max-width: 768px) {
        .grid-header,
        .grid-row {
            grid-template-columns: 56px 1fr 110px 50px;
        }

        .grid-row .col.player {
            width: auto !important;
            margin: 0 !important;
        }
    }

    .grid-header .col.rank,
    .grid-header .col.player,
    .grid-header .col.score,
    .grid-header .col.details,
    .grid-row .col.rank,
    .grid-row .col.score,
    .grid-row .col.details {
        text-align: center;
        justify-content: center;
    }

    .grid-row .col.player {
        width: 300px;
        margin: 0 auto;
    }

    .details-btn {
        padding: 0.6rem 0.6rem;
        border: transparent;
        background: transparent;
        cursor: pointer;
    }

    .char-usage {
        margin-top: 1.5rem;
    }
    .char-usage .usage-grid .grid-header,
    .char-usage .usage-grid .grid-row {
        display: grid;
        grid-template-columns: 100px 1fr 220px;
        gap: 1rem;
        align-items: center;
        padding: 0.6rem 1rem;
        border-bottom: 1px solid var(--bg2);
    }

    .char-usage .grid-header .col.char {
        text-align: center;
        justify-content: center;
    }

    .char-usage .grid-row .col.char {
        width: 290px;
        margin: 0 auto;
    }

    .char-usage .grid-header {
        font-size: 0.8rem;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 600;
    }

    .char-usage .grid-row .rank-num {
        font-weight: 700;
        font-size: 1.75rem;
    }

    .char-usage .col.char {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .char-usage .char-icon {
        width: 48px;
        height: 48px;
        border-radius: 4px;
        object-fit: cover;
        background: var(--bg2);
    }

    .char-usage .col.uses {
        font-weight: 700;
        text-align: center;
    }

    .char-usage .char-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: inherit;
    }

    @media (max-width: 768px) {
        .char-usage .usage-grid .grid-header,
        .char-usage .usage-grid .grid-row {
            grid-template-columns: 56px 1fr 220px;
        }

        .char-usage .grid-row .col.char {
            width: auto !important;
            margin: 0 !important;
        }
    }
</style>

<style is:global>
    .team-modal.hidden {
        display: none;
    }
    .team-modal {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 727;
    }

    .modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.75);
    }

    .modal-panel {
        position: relative;
        z-index: 2;
        background: var(--bg1a);
        border-radius: 10px;
        width: min(480px, 90%);
        max-height: 80vh;
        overflow: auto;
        padding: 1rem;
    }

    .modal-close {
        position: absolute;
        top: 8px;
        right: 10px;
        background: transparent;
        border: none;
        font-size: 2rem;
        cursor: pointer;
    }

    .modal-content .modal-heading {
        display: flex;
        align-items: center;
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .modal-team {
        margin-bottom: 0.6rem;
    }
    .modal-team-title {
        font-weight: 600;
        margin-bottom: 0.25rem;
    }
    .modal-chars {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        flex: 1 1 auto;
    }
    .modal-char-card {
        display: inline-block;
        width: 100px;
        color: inherit;
        font-size: 0.8rem;
    }
    .modal-char-image {
        width: 100px;
        height: 100px;
        background-size: cover;
        border-radius: 8px;
        background-position: top center;
    }
    .modal-char-label {
        font-size: 0.75rem;
        text-align: center;
        margin-top: 0.25rem;
    }

    .modal-build-link {
        padding: 0.35rem 0.6rem;
        border-radius: 6px;
        background: var(--bg2);
        border: 1px solid rgba(255, 255, 255, 0.03);
        color: inherit;
        font-weight: 600;
    }

    .modal-team-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        justify-content: space-between;
        margin-top: 0.4rem;
    }

    .modal-build-wrap {
        width: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-player-head {
        width: 48px;
        height: 48px;
        border-radius: 4px;
        margin-right: 0.5rem;
        object-fit: cover;
        vertical-align: middle;
    }
</style>
