---
interface Props {
    placeholder?: string;
    value?: string;
}

const { placeholder = 'Search...', value = '' } = Astro.props as Props;
---

<div class="search-wrap">
    <input id="search" type="search" placeholder={placeholder} value={value} autofocus />
</div>

<style>
    .search-wrap {
        display: flex;
        position: sticky;
        top: var(--nav-height);
        z-index: 1;
        background: var(--bg1a);

        input[type='search'] {
            flex: 1 1 auto;
            backdrop-filter: blur(5px);
            border: var(--muted) 3px solid;
            border-radius: 6px;
            background: var(--bg1a);
            padding: 0.75rem;
            color: var(--text);
            accent-color: var(--accent);
            font-size: 1.25rem;

            &:focus {
                outline: none;
                border-color: var(--accent);
            }

            &::-webkit-search-cancel-button {
                filter: sepia(100%) saturate(900%) hue-rotate(55deg);
                padding-left: 0.3rem;
            }
        }
    }
</style>
