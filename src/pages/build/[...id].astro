---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import Tabs from '@/components/Tabs.astro';
import { packPotentialData, unpackPotentialData } from '@/scripts/potentialPack.js';

export const prerender = false;

const DATA_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/EN/bin/CharPotential.json';
const CHARACTER_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/character.json';
const ITEM_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/item.json';

const { params, request } = Astro;
const id = Array.isArray(params.id) ? params.id.join('/') : params.id;

const data = await fetch(DATA_URL).then((res) => res.json());
const characterData = await fetch(CHARACTER_URL).then((res) => res.json());
const itemData = await fetch(ITEM_URL).then((res) => res.json());

const unpack = unpackPotentialData(id, data);
if (!unpack) {
    throw Astro.redirect('/404', 302);
}

const isValid = unpack.every((c) => characterData[c.CharId]) && unpack.every((c) => c.Potentials.every((p) => itemData[p.Id]));
const characterNamesList = isValid ? unpack.map((c) => characterData[c.CharId].name).join(', ') : '';
const levelCountSummary = isValid ? unpack.map((c) => c.Potentials.reduce((s, p) => s + p.Level, 0)).join('/') : '';
const totalPotentialsLevel = isValid ? unpack.reduce((acc, c) => acc + c.Potentials.reduce((s, p) => s + p.Level, 0), 0) : 0;
const desc = isValid ? `${characterNamesList} • ${levelCountSummary} • ${totalPotentialsLevel} total` : 'Build preset id is not valid';
---

<Layout title={`${id} | stelladb`} description={desc} bigImage={isValid} image={isValid ? `https://stelladb.pages.dev/og/build/${id}` : undefined}>
    <div class="search-wrap">
        <label for="search" class="visually-hidden">Search</label>
        <input id="search" type="search" placeholder="Build preset id" value={id} autofocus />
    </div>

    {
        isValid && (
            <div id="preview">
                <img src={`/og/build/${id}`} />
            </div>
        )
    }

    {!isValid && <div class="no-results">Build preset id is not valid</div>}
</Layout>

<script>
    // @ts-nocheck
    const input = document.querySelector('#search');

    input.addEventListener('keypress', async (e) => {
        if (e.key === 'Enter') {
            const val = input.value.trim();
            if (val) {
                window.location.href = `/build/${val}`;
            }
        }
    });
</script>

<style>
    .search-wrap {
        display: flex;
        position: sticky;
        top: var(--nav-height);
        z-index: 1;
        background: var(--bg1a);
    }

    input[type='search'] {
        flex: 1 1 auto;
        backdrop-filter: blur(5px);
        border: var(--muted) 3px solid;
        border-radius: 6px;
        background: var(--bg1a);
        padding: 0.75rem;
        color: var(--text);
        accent-color: var(--accent);
        font-size: 1.25rem;
    }

    input[type='search']:focus {
        outline: none;
        border-color: var(--accent);
    }

    input[type='search']::-webkit-search-cancel-button {
        filter: sepia(100%) saturate(900%) hue-rotate(55deg);
        padding-left: 0.3rem;
    }

    .visually-hidden {
        position: absolute !important;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(1px, 1px, 1px, 1px);
        margin: -1px;
        border: 0;
        padding: 0;
        white-space: nowrap;
    }

    #preview {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
    }

    .no-results {
        margin-top: 2rem;
        color: var(--text);
        font-size: 1.5rem;
        text-align: center;
    }
</style>
